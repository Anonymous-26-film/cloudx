# TMDB API - Get your free key at https://www.themoviedb.org/settings/api
# 1. Create an account or log in
# 2. Go to Settings > API
# 3. Generate an API Key (v3 auth)
VITE_TMDB_API_KEY=your_api_key_here
VITE_TMDB_ACCESS_TOKEN=your_access_token_here

# IPTV Sources - Comma-separated playlist URLs
# Default channel sources are baked into the app; use this to override or add more.
VITE_IPTV_SOURCES=https://iptv-org.github.io/iptv/index.m3u,https://raw.githubusercontent.com/hnnyo/cct/refs/heads/main/aku.m3u